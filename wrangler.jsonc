{
  "name": "hada-reboot",
  "main": ".open-next/worker.js",
  "compatibility_date": "2024-09-23",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": ".open-next/assets"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "hada-db",
      "database_id": "<YOUR_D1_DATABASE_ID>"
    }
  ]
}
